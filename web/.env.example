# Sao chép file này thành .env.local rồi điền giá trị thật. KHÔNG commit .env.local.

# ===== MongoDB =====
# Atlas non-SRV (liệt kê host trực tiếp) nếu mạng không tra được DNS SRV.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=quynhphu

# ===== Auth — bí mật ký JWT phiên đăng nhập (đừng chia sẻ) =====
# Sinh chuỗi ngẫu nhiên: openssl rand -hex 32
AUTH_SECRET=

# ===== URL app (dùng cho link trong email) =====
APP_URL=http://localhost:3001

# ===== Gmail SMTP (Nodemailer) =====
# Tạo App Password: Google Account → Security → 2-Step Verification → App passwords.
# Để trống GMAIL_APP_PASSWORD: app vẫn chạy, link xác nhận/đặt lại sẽ IN RA TERMINAL.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ---- Cloudinary (lưu ảnh). Để trống = ghi local public/uploads (dev) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=quynhphutoi

# ---- Google reCAPTCHA v2 (ô tick "Tôi không phải robot") ----
# Tạo khóa tại https://www.google.com/recaptcha/admin → chọn loại:
#   reCAPTCHA v2 → "I'm not a robot" Checkbox.
# Thêm domain thật + localhost (để test). LƯU Ý: khóa v3 KHÔNG dùng được cho v2.
# Để trống cả hai = bỏ qua xác minh (tiện cho dev/local).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ---- Chống load lại trang liên tục (anti-flood, middleware) ----
RELOAD_MAX=100
RELOAD_WINDOW_SEC=100
RELOAD_BLOCK_SEC=60
RELOAD_BLOCK_MAX_SEC=3600
RELOAD_OFFENSE_RESET_SEC=3600

# ---- Tự tạo tài khoản admin khi server khởi động (để trống ADMIN_PASSWORD = bỏ qua) ----
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Quản trị viên

# ---- Nguồn tin ngoài (admin "Tạo tin từ nguồn ngoài") ----
# Mặc định dùng NewsAPI.org. Lấy key tại https://newsapi.org/register.
# LƯU Ý: gói free (Developer) của NewsAPI chỉ chạy ở localhost/dev, không dùng được
# trên domain production. Để trống NEWS_API_KEY = ẩn nút import.
NEWS_API_KEY=
# (tuỳ chọn) Đổi endpoint nếu dùng proxy/API tương thích shape NewsAPI.
NEWS_API_URL=https://newsapi.org/v2/everything
# (tuỳ chọn) Từ khoá tìm mặc định khi mở modal.
NEWS_API_QUERY=Quỳnh Phụ
